# AWS Configuration
AWS_PROFILE=default
AWS_DEFAULT_REGION=us-west-2

# Budget
BUDGET_AMOUNT=50
BUDGET_EMAIL=your@email.com

# Initial token user
INITIAL_TOKEN_USER=admin

# Cloudflare fronting (DNS records: us/jp/tw.<domain> must be proxied / orange cloud)
CF_EDGE_DOMAIN=icered.com
VLESS_WS_PATH=/ws
VLESS_WS_PORT=443

# Cloudflare API Token (needed for setup-cloudflare-dns.sh)
# Export in your shell (recommended) instead of committing to a file:
# export CLOUDFLARE_API_TOKEN="..."

# Origin SG hardening toggles (harden-cloudflare-origin.sh)
PRUNE_NON_CF_443=1
CLOSE_8080=1
